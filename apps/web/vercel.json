{
  "framework": "nextjs",
  "installCommand": "cd ../.. && npm ci",
  "buildCommand": "cd ../.. && npx prisma generate && npm run build:web",
  "outputDirectory": ".next-build",
  "crons": [
    {
      "path": "/api/fomo/cron/daily-30/trading",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/fomo/cron/daily-30/financial",
      "schedule": "10 21 * * *"
    },
    {
      "path": "/api/fomo/cron/daily-30/editor",
      "schedule": "20 21 * * *"
    },
    {
      "path": "/api/fomo/cron/quality-slo",
      "schedule": "30 21 * * *"
    },
    {
      "path": "/api/fomo/cron/ledger-outcomes",
      "schedule": "40 21 * * *"
    }
  ]
}
