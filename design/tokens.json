{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "FOMO Club 디자인 토큰 — DTCG(W3C) 단일 소스. Figma Variables ⇄ DESIGN.md ⇄ 코드(@fomo/core/Tailwind/fomoTheme)의 교환 허브. 감정색은 packages/fomo-core/src/types.ts EMOTION_COLORS와 동일값 유지(드리프트 테스트로 강제).",
  "color": {
    "$type": "color",
    "ink": { "$value": "#000000", "$description": "앱 배경(순수 검정)" },
    "surface": { "$value": "#0E0E0E", "$description": "카드/표면" },
    "elevated": { "$value": "#1A1A1A", "$description": "트랙/칩 배경" },
    "hairline": { "$value": "#2A2A2A", "$description": "경계선" },
    "muted": { "$value": "#8A8A8A", "$description": "보조 텍스트" },
    "whiteout": { "$value": "#FAFAFA", "$description": "본문/주요 텍스트, 포모의 흰 눈" },
    "emotion": {
      "fomo": { "$value": "#FF5A36", "$description": "FOMO — 달아오르는 불꽃(빨강~주황)" },
      "fear": { "$value": "#38BDF8", "$description": "공포 — 얼어붙는 차가움(파랑~청록)" },
      "regret": { "$value": "#8B7CF6", "$description": "후회 — 가라앉아 곱씹음(보라~남색)" },
      "greed": { "$value": "#34D399", "$description": "탐욕 — 돈의 욕망(초록/황금)" },
      "conviction": { "$value": "#FACC15", "$description": "확신 — 또렷한 자신감(노랑/골드)" }
    },
    "primary": { "$value": "{color.emotion.fomo}", "$description": "시그니처(린터용 primary). 시각상 base는 흑백, 시그니처 포인트는 FOMO 레드." },
    "background": { "$value": "{color.ink}" },
    "text": { "$value": "{color.whiteout}" },

    "_designMd": { "$value": "—", "$description": "▼ DESIGN.md(v1) 정본 토큰. 위 ink/surface/emotion 등은 레거시(점진 마이그레이션). 충돌 시 DESIGN.md/아래 값이 이긴다." },
    "canvas": { "$value": "#0B0B0C", "$description": "최하단 배경" },
    "surfaceBase": { "$value": "#141416", "$description": "기본 표면(DESIGN.md surface)" },
    "surfaceRaised": { "$value": "#1A1A1D", "$description": "카드" },
    "surfaceOverlay": { "$value": "#202024", "$description": "모달·시트" },
    "hairlineSoft": { "$value": "rgba(255,255,255,0.08)", "$description": "기본 보더(DESIGN.md hairline)" },
    "hairlineStrong": { "$value": "rgba(255,255,255,0.14)", "$description": "강조 보더" },
    "textPrimary": { "$value": "#F2F2F0", "$description": "주요 텍스트" },
    "textSecondary": { "$value": "#8A8A86", "$description": "보조 텍스트" },
    "textTertiary": { "$value": "#5A5A57", "$description": "3차 텍스트" },
    "brand": {
      "$description": "브랜드 액센트 — 역할 인코딩(좋다/사라 아님). 등락에 절대 사용 금지.",
      "orange500": { "$value": "#FF5A1F", "$description": "주목 열기/강도 — 🔥, 포모 미터, 픽셀 스파크라인" },
      "orange600": { "$value": "#E0440F", "$description": "오렌지 강조" },
      "orangeDim": { "$value": "#5A2A14", "$description": "저강도 트랙" },
      "neon500": { "$value": "#D8FF3A", "$description": "발견·인터랙션·💎 — 1차 CTA, 활성, live" },
      "neon600": { "$value": "#B6E000", "$description": "네온 hover" },
      "neonDim": { "$value": "#2E3A0A", "$description": "네온 저강도" }
    },
    "market": {
      "$description": "봉인색 — 등락 데이터 전용(브랜드로 절대 사용 금지). 가격·%·변동에만.",
      "up": { "$value": "#FF4D4D", "$description": "상승(KR red=up)" },
      "down": { "$value": "#4D8DFF", "$description": "하락" },
      "flat": { "$value": "#8A8A86", "$description": "보합" }
    },
    "evidence": {
      "$description": "근거 보조 — 헤어라인 수준 큐만, fill 판정 금지, 텍스트 항상 동반.",
      "green": { "$value": "#3FB984", "$description": "그린플래그(보조)" },
      "redflag": { "$value": "#E0A82E", "$description": "레드플래그(보조, 등락색과 구분)" }
    }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "body": { "$value": ["Pretendard", "system-ui", "sans-serif"], "$description": "본문(한글+라틴), 담담한 목소리" },
    "pixel": { "$value": ["Galmuri11", "Departure Mono", "monospace"], "$description": "픽셀 악센트(숫자·라벨·캘린더), 인디게임의 몸" },
    "sans": { "$value": ["Pretendard", "system-ui", "sans-serif"], "$description": "DESIGN.md 한글·문장(=body)" },
    "display": { "$value": ["Departure Mono", "Galmuri11", "monospace"], "$description": "DESIGN.md 디스플레이(라틴 숫자·티커). 한글 금지. 폰트 에셋 셋업 후 Departure Mono 우선." },
    "mono": { "$value": ["Departure Mono", "Galmuri11", "monospace"], "$description": "DESIGN.md 데이터(작은 수치·%·가격·타임스탬프). 한글 금지." }
  },
  "typography": {
    "$type": "typography",
    "display": { "$value": { "fontFamily": "{fontFamily.pixel}", "fontSize": "64px", "lineHeight": 1 }, "$description": "FOMO Index 대형 숫자" },
    "headingLg": { "$value": { "fontFamily": "{fontFamily.body}", "fontSize": "28px", "fontWeight": 600 } },
    "heading": { "$value": { "fontFamily": "{fontFamily.body}", "fontSize": "20px", "fontWeight": 600 } },
    "body": { "$value": { "fontFamily": "{fontFamily.body}", "fontSize": "16px", "fontWeight": 400 } },
    "label": { "$value": { "fontFamily": "{fontFamily.pixel}", "fontSize": "13px" }, "$description": "상태 라벨/메타(무관심·광기, 캘린더)" },
    "caption": { "$value": { "fontFamily": "{fontFamily.body}", "fontSize": "12px" } }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "8px" },
    "md": { "$value": "12px" },
    "lg": { "$value": "16px" },
    "pill": { "$value": "9999px" }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" },
    "2xl": { "$value": "40px" }
  }
}
