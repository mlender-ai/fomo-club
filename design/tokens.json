{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "FOMO Club 디자인 토큰 — DTCG(W3C) 단일 소스. Figma Variables ⇄ DESIGN.md ⇄ 코드(@fomo/core/Tailwind/fomoTheme)의 교환 허브. 감정색은 packages/fomo-core/src/types.ts EMOTION_COLORS와 동일값 유지(드리프트 테스트로 강제).",
  "color": {
    "$type": "color",
    "ink": { "$value": "#000000", "$description": "앱 배경(순수 검정)" },
    "surface": { "$value": "#0E0E0E", "$description": "카드/표면" },
    "elevated": { "$value": "#1A1A1A", "$description": "트랙/칩 배경" },
    "hairline": { "$value": "#2A2A2A", "$description": "경계선" },
    "muted": { "$value": "#8A8A8A", "$description": "보조 텍스트" },
    "whiteout": { "$value": "#FAFAFA", "$description": "본문/주요 텍스트, 포모의 흰 눈" },
    "emotion": {
      "fomo": { "$value": "#FF5A36", "$description": "FOMO — 달아오르는 불꽃(빨강~주황)" },
      "fear": { "$value": "#38BDF8", "$description": "공포 — 얼어붙는 차가움(파랑~청록)" },
      "regret": { "$value": "#8B7CF6", "$description": "후회 — 가라앉아 곱씹음(보라~남색)" },
      "greed": { "$value": "#34D399", "$description": "탐욕 — 돈의 욕망(초록/황금)" },
      "conviction": { "$value": "#FACC15", "$description": "확신 — 또렷한 자신감(노랑/골드)" }
    },
    "primary": { "$value": "{color.emotion.fomo}", "$description": "시그니처(린터용 primary). 시각상 base는 흑백, 시그니처 포인트는 FOMO 레드." },
    "background": { "$value": "{color.ink}" },
    "text": { "$value": "{color.whiteout}" }
  },
  "fontFamily": {
    "$type": "fontFamily",
    "body": { "$value": ["Pretendard", "system-ui", "sans-serif"], "$description": "본문(한글+라틴), 담담한 목소리" },
    "pixel": { "$value": ["Galmuri11", "Departure Mono", "monospace"], "$description": "픽셀 악센트(숫자·라벨·캘린더), 인디게임의 몸" }
  },
  "typography": {
    "$type": "typography",
    "display": { "$value": { "fontFamily": "{fontFamily.pixel}", "fontSize": "64px", "lineHeight": 1 }, "$description": "FOMO Index 대형 숫자" },
    "headingLg": { "$value": { "fontFamily": "{fontFamily.body}", "fontSize": "28px", "fontWeight": 600 } },
    "heading": { "$value": { "fontFamily": "{fontFamily.body}", "fontSize": "20px", "fontWeight": 600 } },
    "body": { "$value": { "fontFamily": "{fontFamily.body}", "fontSize": "16px", "fontWeight": 400 } },
    "label": { "$value": { "fontFamily": "{fontFamily.pixel}", "fontSize": "13px" }, "$description": "상태 라벨/메타(무관심·광기, 캘린더)" },
    "caption": { "$value": { "fontFamily": "{fontFamily.body}", "fontSize": "12px" } }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "12px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "20px" },
    "pill": { "$value": "9999px" }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" },
    "2xl": { "$value": "40px" }
  }
}
